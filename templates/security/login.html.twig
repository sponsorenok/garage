{% extends 'base.html.twig' %}

{% block title %}Sign in{% endblock %}
{% block body_class %}login-page-body{% endblock %}
{% block body %}
    <style>
        html, body.login-page-body {
            height: 100%;
            margin: 0;
            overflow: hidden;
        }
        .login-page {
            min-height: 100vh;
            position: relative;
            display: grid;
            place-items: center;
            padding: 24px;
            overflow: hidden;
        }

        /* Full-page background image */
        .login-bg {
            position: absolute;
            inset: 0;
            background-image: url("{{ asset('/images/bg.jpg') }}"); /* <-- change path */
            background-size: cover;
            background-position: center;
            filter: saturate(1.05);
            transform: scale(1.02);
        }

        /* Soft dark overlay for readability */
        .login-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(
                135deg,
                rgba(0, 0, 0, 0.55),
                rgba(0, 0, 0, 0.25)
            );
        }

        .login-card {
            position: relative;
            width: min(420px, 100%);
            background: rgba(255, 255, 255, 0.92);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.45);
            border-radius: 18px;
            padding: 28px;
            box-shadow: 0 18px 50px rgba(0,0,0,0.28);
        }

        .login-title {
            margin: 0 0 14px;
            font-size: 22px;
            font-weight: 700;
            letter-spacing: -0.02em;
            color: #111827;
        }

        .login-subtitle {
            margin: 0 0 18px;
            font-size: 14px;
            color: #4b5563;
        }

        .login-field {
            margin-bottom: 14px;
        }

        .login-label {
            display: block;
            font-size: 12px;
            font-weight: 600;
            color: #374151;
            margin: 0 0 6px;
        }

        .login-input {
            width: 100%;
            padding: 12px 12px;
            border-radius: 12px;
            border: 1px solid #e5e7eb;
            background: #fff;
            outline: none;
            transition: border-color .15s ease, box-shadow .15s ease;
        }

        .login-input:focus {
            border-color: #93c5fd;
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.18);
        }

        .login-actions {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            margin-top: 6px;
        }

        .login-btn {
            width: 100%;
            border: 0;
            padding: 12px 14px;
            border-radius: 12px;
            background: #111827;
            color: #fff;
            font-weight: 700;
            cursor: pointer;
            transition: transform .05s ease, opacity .15s ease;
        }
        .login-btn:hover { opacity: 0.95; }
        .login-btn:active { transform: translateY(1px); }

        .login-alert {
            border-radius: 12px;
            padding: 10px 12px;
            margin-bottom: 12px;
            font-size: 14px;
        }
        .login-alert-danger {
            background: rgba(239, 68, 68, 0.10);
            border: 1px solid rgba(239, 68, 68, 0.25);
            color: #991b1b;
        }
        .login-alert-info {
            background: rgba(59, 130, 246, 0.10);
            border: 1px solid rgba(59, 130, 246, 0.25);
            color: #1e3a8a;
        }

        .login-meta {
            margin-top: 14px;
            font-size: 12px;
            color: #6b7280;
            text-align: center;
        }
        .login-meta a { color: inherit; font-weight: 600; }
    </style>

    <div class="login-page">
        <div class="login-bg"></div>
        <div class="login-overlay"></div>

        <div class="login-card">

            <form method="post" novalidate>
                {% if error %}
                    <div class="login-alert login-alert-danger">
                        {{ error.messageKey|trans(error.messageData, 'security') }}
                    </div>
                {% endif %}

                {% if app.user %}
                    <div class="login-alert login-alert-info">
                        You are logged in as <strong>{{ app.user.userIdentifier }}</strong>.
                        <a href="{{ logout_path() }}">Logout</a>
                    </div>
                {% endif %}

                <h1 class="login-title">Sign in</h1>
                <p class="login-subtitle">Use your account to access the dashboard.</p>

                <div class="login-field">
                    <label class="login-label" for="username">Username</label>
                    <input
                        class="login-input"
                        type="text"
                        value="{{ last_username }}"
                        name="_username"
                        id="username"
                        autocomplete="username"
                        required
                        autofocus
                    >
                </div>

                <div class="login-field">
                    <label class="login-label" for="password">Password</label>
                    <input
                        class="login-input"
                        type="password"
                        name="_password"
                        id="password"
                        autocomplete="current-password"
                        required
                    >
                </div>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <div class="login-actions">
                    <button class="login-btn" type="submit">Sign in</button>
                </div>

                <div class="login-meta">
                    © {{ "now"|date("Y") }} — Secure access
                </div>
            </form>
        </div>
    </div>
{% endblock %}
