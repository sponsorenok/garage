{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}Створити закупівлю з заявок{% endblock %}

{% block main %}
    <div class="content-panel p-3">
        <p class="mb-3">Обрано заявок: <b>{{ ids|length }}</b></p>

        {{ form_start(form) }}
        {{ form_widget(form) }}
        {% for id in ids %}
            <input type="hidden" name="entityIds[]" value="{{ id }}">
        {% endfor %}

        <div class="mt-3">
            <button class="btn btn-primary">Створити закупівлю</button>
            <a class="btn btn-secondary" href="{{ ea_url().setAction('index') }}">Скасувати</a>
        </div>
        {{ form_end(form) }}
    </div>
{% endblock %}
